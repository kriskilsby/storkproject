      <!-- New Map Section -->
      <section id="map-section">
        <div id="map-layout-wrapper" style="display: flex; flex-direction: column; gap: 1rem;">

          <div id="map-controls">
            <H5>Filter GPS Points On Map</H5>

            <!-- Year Filter -->
            <div>
              <label for="year-select" class="form-label mb-0 me-2">Year:</label>
              <select id="year-select" class="form-select d-inline w-auto">
                <option value="all">All Years</option>
              </select>
            </div>

            <!-- Bird Filter -->
            <div>
              <label for="bird-select" class="form-label mb-0 me-2">Bird:</label>
              <select id="bird-select" class="form-select d-inline w-auto">
                <option value="all">All Birds</option>
              </select>
            </div>
          
            <!-- Month Filter -->
            <div>
              <label class="form-label mb-0 me-2">Months:</label>
              <div class="mb-1">
                <button type="button" class="btn btn-sm btn-outline-primary me-2" onclick="toggleAll('month', true)">Select All</button>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleAll('month', false)">Deselect All</button>
              </div>
              <div class="btn-group btn-group-sm" role="group" aria-label="Month Filter">
                <% const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]; %>
                <% months.forEach((m, i) => { %>
                  <input type="checkbox" class="btn-check" id="month-<%= i %>" value="<%= i + 1 %>">
                  <label class="btn btn-outline-primary" for="month-<%= i %>"><%= m %></label>
                <% }); %>
              </div>
            </div>

            <!-- Time Slot Filter -->
            <div id="time-slot-filters">
              <label class="form-label mb-0 me-2">Time Slots:</label>
              <div class="mb-1">
                <button type="button" class="btn btn-sm btn-outline-secondary me-2" onclick="toggleAll('hour', true)">Select All</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll('hour', false)">Deselect All</button>
              </div>
              <div class="btn-group btn-group-sm" role="group" aria-label="Hour Filter">
                <% const slots = ["0–3", "3–6", "6–9", "9–12", "12–15", "15–18", "18–21", "21–24"]; %>
                <% slots.forEach((s, i) => { %>
                  <input type="checkbox" class="btn-check" id="hour-<%= i %>" value="<%= i %>">
                  <label class="btn btn-outline-secondary" for="hour-<%= i %>"><%= s %></label>
                <% }); %>
              </div>
            </div>
          </div>

          <div id="main-container">
            <!-- Legend Sidebar -->
            <div id="legend" class="legend me-3"></div>

            <!-- Leaflet Map -->
            <div id="map" style="flex: 1;"></div>
          </div>
        </div>
      </section>

