      <!-- Clustering Form -->
      <section class="container my-4">
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h4 class="card-title mb-4">Select Your Parameters and Run Clustering</h4>

            <form id="clusteringForm" class="row g-3">
              <!-- Method -->
              <div class="col-md-3">
                <label for="method" class="form-label">Clustering Method</label>
                <select id="method" name="method" class="form-select">
                  <option value="kmeans">KMeans</option>
                  <option value="dbscan">DBSCAN</option>
                  <option value="hdbscan">HDBSCAN</option>
                </select>
              </div>

              <!-- KMeans Params -->
              <div id="kmeans-params" class="col-md-2 method-params">
                <label for="n_clusters" class="form-label"># Clusters</label>
                <input type="number" name="n_clusters" class="form-control" value="3" min="1">
              </div>

              <!-- DBSCAN Params -->
              <div id="dbscan-params" class="method-params d-none col-md-4">
                <div class="row">
                  <div class="col">
                    <label for="eps" class="form-label">EPS</label>
                    <input type="number" name="eps" step="0.01" min="0" max="10" class="form-control" value="0.5">
                  </div>
                  <div class="col">
                    <label for="min_samples" class="form-label">Min Samples</label>
                    <input type="number" name="min_samples" class="form-control" value="5">
                  </div>
                </div>
              </div>
               
              <!-- HDBSCAN Params -->
              <div id="hdbscan-params" class="method-params d-none col-md-2">
                <label for="min_cluster_size" class="form-label">Min Cluster Size</label>
                <input type="number" name="min_cluster_size" class="form-control" value="5">
              </div>

              <!-- Decimal Precision -->
              <div class="col-md-2">
                <label for="decimal_places" class="form-label">Decimal Precision</label>
                <select name="decimal_places" class="form-select">
                  <option value="-1">Standard (full)</option>
                  <option value="3" selected>3 (≈111m)</option>
                  <option value="4">4 (≈11m)</option>
                  <option value="5">5 (≈1.1m)</option>
                </select>
              </div>

              <!-- Interval Grouping -->
              <div class="col-md-2">
                <label for="interval_minutes" class="form-label">Time Interval</label>
                <select name="interval_minutes" class="form-select">
                  <option value="0">0 min</option>
                  <option value="1">1 min</option>
                  <option value="5">5 min</option>
                  <option value="10">10 min</option>
                  <option value="15" selected>15 min</option>
                  <option value="20">20 min</option>
                  <option value="30">30 min</option>
                </select>
              </div>

              <!-- Sample Rate -->
              <div class="col-md-2">
                <label for="sample_rate" class="form-label">Sample Rate</label>
                <input type="number" name="sample_rate" class="form-control" value="50" min="1">
              </div>

              <!-- Feature Toggles -->
              <div class="col-md-12">
                <!-- <h4 class="card-title mb-4">Select Your Parameters and Run Clustering</h4> -->
                <label class="form-label"><h5>Include Features in Clustering</h5></label>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_coordinates" id="use_coordinates" checked>
                  <label class="form-check-label" for="use_coordinates">Use Coordinates</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_interval_mins" id="use_interval_mins" checked>
                  <label class="form-check-label" for="use_interval_mins">Use Interval Minites</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_distance" id="use_distance">
                  <label class="form-check-label" for="use_distance">Distance</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_heading" id="use_heading">
                  <label class="form-check-label" for="use_heading">Heading</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_year" id="use_year" checked>
                  <label class="form-check-label" for="use_year">Year</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="use_month" id="use_month" checked>
                  <label class="form-check-label" for="use_month">Month</label>
                </div>

                <div class="form-check mt-2">
                  <input class="form-check-input" type="checkbox" name="use_scaling" id="use_scaling">
                  <label class="form-check-label" for="use_scaling">Use Feature Scaling (StandardScaler)</label>
                </div>
              </div>

              <!-- Submit Button -->
              <div class="col-12 d-flex align-items-center">
                <button type="submit" class="btn btn-primary me-3">Run Clustering</button>
                <span id="clustering-timer" class="text-muted fw-bold"></span>
              </div>

              <!-- Test the clustering success -->
              <div id="clusteringMetrics" style="margin-top: 1rem; font-size: 0.95rem;">
                <h6>Clustering Metrics</h6>
                <ul id="metricsList" style="padding-left: 1.2rem;"></ul>
              </div>


            </form>

