      <section id="summary-table-section" class="container my-4 mb-1 mt-2">
        <div class="main-card card shadow-sm border-0 rounded">
          <div id="summary-table-card" class="card-body">
            <label for="summary-table-card-title" class="form-label fw-bold deferred-tooltip"
              data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true"
              data-title-html="Displays yearly variation in total, large, and small clusters for each tracked individual.">
              <h3 class="card-title mb-2 mt-2">Cluster Size Trends by Individual & Year</h3>
            </label>
            <!-- Keep the table skeleton only -->
            <table id="birdYearTable" class="display nowrap" style="width:100%">
              <!-- JS will build thead + tbody -->
            </table>
            <!-- kk updated section above ################## -->

            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2 mt-3">
              <!-- Button group -->
              <div class="btn-group" role="group" aria-label="Metric toggle">
                <button class="btn btn-outline-primary metric-toggle active" data-metric="totalClusters">
                Total Clusters
                </button>
                <button class="btn btn-outline-success metric-toggle" data-metric="largeClusters">
                  Large Clusters
                </button>
                <button class="btn btn-outline-info metric-toggle" data-metric="smallClusters">
                  Small Clusters
                </button>
              </div>
              <!-- Dropdown -->
              <div class="d-flex align-items-center flex-nowrap">
                <label for="largeThreshold" class="form-label me-2 mb-0 text-nowrap">Large Cluster (%):</label>
                <select id="largeThreshold" class="form-select form-select-sm" style="max-width: 120px;">
                  <option value="2" selected>2%</option>
                  <option value="5">5%</option>
                  <option value="10">10%</option>
                  <option value="20">20%</option>
                  <option value="30">30%</option>
                  <option value="40">40%</option>
                  <option value="50">50%</option>
                </select>
              </div>
            </div> 
          </div>
        </div>

        <div class="main-card card shadow-sm border-0 rounded">
          <div id="chart-card" class="card-body">
            <!-- Flex row with dropdown, title, and buttons -->
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-2 mt-2">
              
              <!-- Dropdown -->
              <div class="d-flex flex-column">
                <label for="chartYearSelect" class="form-label mb-1">Select Year:</label>
                <select id="chartYearSelect" class="form-select">
                  <option value="all">All Years</option>
                </select>
              </div>  

              <!-- Title with tooltip -->
              <h3 id="chart-card-title" 
                  class="card-title mb-0 text-center flex-grow-1 deferred-tooltip"
                  data-bs-toggle="tooltip" 
                  data-bs-placement="top" 
                  data-bs-html="true"
                  data-title-html="This chart shows variation in clusters over time.">
                Cluster Trends by Year
              </h3>

              <!-- Toggle buttons -->
              <div class="btn-group" role="group">
                <button class="btn btn-primary chart-value-toggle active" data-value="Clusters">Clusters</button>
                <button class="btn btn-primary chart-value-toggle" data-value="Points">Points</button>
              </div>
            </div>

            <!-- Chart container -->
            <div id="birdYearChartsContainer" style="width:100%; margin-top:20px;"></div>
          </div>
        </div>
      </section>


      <!-- Leaflet JS -->
      <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    </main>

